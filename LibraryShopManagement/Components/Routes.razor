@using LibraryShopManagement.Components.Layout
@using LibraryShopManagement.Components.Pages

<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        @* AuthorizeRouteView enforces [Authorize] attributes on all pages.
           NotAuthorized renders RedirectToLoginPage which navigates to /login.
           This is the centralized auth guard — pages only need [Authorize] attribute. *@
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLoginPage />
            </NotAuthorized>
            <Authorizing>
                <MudProgressLinear Indeterminate Color="Color.Primary" />
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="typeof(MainLayout)">
            <MudContainer Class="d-flex flex-column align-center justify-center" Style="height:60vh;">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Style="font-size:5rem;" />
                <MudText Typo="Typo.h4" Class="mt-4" Color="Color.Primary">Page Not Found</MudText>
                <MudButton Href="/home" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Go Home</MudButton>
            </MudContainer>
        </LayoutView>
    </NotFound>
</Router>
