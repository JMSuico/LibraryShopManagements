@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject IThemeService ThemeService
@inject NavigationManager Navigation

@* ═══════════════════════════════════════════════════════════════════════════
   MainLayout.razor — THEME CONTROLLER (Single Source of Truth)
   ► Every UI color defined here via MudThemeProvider + CSS custom properties
   ► CSS vars (--clr-*) used in all Style="" attributes across the app
   ► No colors are hardcoded in any page or child component
   ═══════════════════════════════════════════════════════════════════════════ *@

<MudThemeProvider Theme="@_theme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>

    @* ── NAVBAR ───────────────────────────────────────────────────────────── *@
    <MudAppBar Elevation="0" Fixed="true" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudIcon Icon="@Icons.Material.Filled.AutoStories"
                 Class="mr-2" Color="Color.Primary" />
        <MudText Typo="Typo.h6" Color="Color.Default"
                 Style="font-weight:700;letter-spacing:.04em;">
            Library Shop
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1 mt-1">
            Management
        </MudText>
        <MudSpacer />

        @* Dark/Light Toggle *@
        <MudTooltip Text="@(ThemeService.IsDarkMode ? "Light Mode" : "Dark Mode")"
                    Placement="Placement.Bottom" Color="Color.Primary">
            <MudIconButton Color="Color.Inherit" OnClick="ToggleTheme">
                <MudIcon Icon="@(ThemeService.IsDarkMode
                                             ? Icons.Material.Filled.LightMode
                                             : Icons.Material.Filled.DarkMode)"
                         Color="Color.Warning" />
            </MudIconButton>
        </MudTooltip>

        @* Logged-in User *@
        @if (_currentUser != null)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary"
                     Class="mx-2 d-none d-sm-block">
                @_currentUser.Username
            </MudText>
            <MudTooltip Text="Logout" Placement="Placement.Bottom" Color="Color.Primary">
                <MudIconButton Color="Color.Inherit"
                               OnClick="@(() => Navigation.NavigateTo("/logout"))">
                    @if (!string.IsNullOrEmpty(_currentUser.ProfileImage))
                    {
                        <MudAvatar Color="Color.Primary"
                                   Style="width:32px;height:32px;border:2px solid var(--clr-primary);">
                            <MudImage Src="@_currentUser.ProfileImage"
                                      Style="width:100%;height:100%;object-fit:cover;" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary"
                                   Style="width:32px;height:32px;font-size:.85rem;
                                                  font-weight:700;border:2px solid var(--clr-primary);">
                            @(_currentUser.FirstName.Length > 0
                                                ? _currentUser.FirstName[..1].ToUpper() : "?")
                        </MudAvatar>
                    }
                </MudIconButton>
            </MudTooltip>
        }
    </MudAppBar>

    @* ── SIDEBAR ──────────────────────────────────────────────────────────── *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Color="Color.Dark">
        <MudDrawerHeader Style="padding:16px 20px;">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Primary" Style="width:38px;height:38px;">
                    <MudIcon Icon="@Icons.Material.Filled.AutoStories"
                             Color="Color.Surface" Style="font-size:1.2rem;" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.subtitle1" Color="Color.Default"
                             Style="font-weight:700;line-height:1.2;">
                        LibraryShop
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="font-size:.7rem;">
                        Management System
                    </MudText>
                </div>
            </MudStack>
        </MudDrawerHeader>
        <MudDivider />
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private User? _currentUser;

    protected override void OnInitialized()
    {
        RefreshUser();
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        ThemeService.OnThemeChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }

    private void RefreshUser()
    {
        var p = (CustomAuthenticationStateProvider)AuthStateProvider;
        _currentUser = p.CurrentUser;
    }

    private void OnAuthStateChanged(Task<AuthenticationState> _)
    {
        RefreshUser(); InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTheme() => await ThemeService.ToggleThemeAsync();
    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    // ╔═══════════════════════════════════════════════════════════════════════╗
    // ║  COLOR SYSTEM — ALL COLORS DEFINED HERE (MudBlazor 9 compatible)     ║
    // ║                                                                       ║
    // ║  MudThemeProvider controls:                                           ║
    // ║    Primary · Secondary · Accent · Background · AppBar · Drawer        ║
    // ║    Text · Icons · Tables · Inputs · Dividers · Overlays · States      ║
    // ║                                                                       ║
    // ║  CSS custom properties (--clr-*) mirror the palette and are used in: ║
    // ║    MudText Style · MudAvatar Style · MudChip Style                   ║
    // ║    MudPaper Style · MudIcon Style · MudIconButton Style              ║
    // ║    Any inline Style="" attribute throughout the app                   ║
    // ╚═══════════════════════════════════════════════════════════════════════╝
    private readonly MudTheme _theme = new()
    {
        // ── LIGHT PALETTE (valid MudBlazor 9 properties only) ──────────────
        PaletteLight = new PaletteLight
        {
            // Primary — Neon Violet (buttons, active nav, primary icons)
            Primary = "#8B5CF6",
            PrimaryContrastText = "#FFFFFF",
            PrimaryDarken = "#7C3AED",
            PrimaryLighten = "#C4B5FD",

            // Secondary — Neon Cyan (secondary buttons, secondary icons)
            Secondary = "#06B6D4",
            SecondaryContrastText = "#FFFFFF",
            SecondaryDarken = "#0891B2",
            SecondaryLighten = "#A5F3FC",

            // Tertiary — Soft Pink (accent chips, badges, tags)
            Tertiary = "#F472B6",
            TertiaryContrastText = "#FFFFFF",

            // State colors
            Success = "#10B981",
            SuccessContrastText = "#FFFFFF",
            Warning = "#F59E0B",
            WarningContrastText = "#1A1A1A",
            Error = "#EF4444",
            ErrorContrastText = "#FFFFFF",
            Info = "#3B82F6",
            InfoContrastText = "#FFFFFF",

            // Dark slot — used by AppBar + Drawer Color="Color.Dark"
            Dark = "#EEF2FF",
            DarkContrastText = "#1E1B4B",
            DarkDarken = "#E0E7FF",
            DarkLighten = "#F5F3FF",

            // Background colors
            Background = "#F1F5FF",
            BackgroundGray = "#EEF2FF",
            Surface = "#FFFFFF",

            // Navbar / AppBar
            AppbarBackground = "#EEF2FF",
            AppbarText = "#1E1B4B",

            // Sidebar / Drawer
            DrawerBackground = "#F5F3FF",
            DrawerText = "#374151",
            DrawerIcon = "#8B5CF6",

            // Text
            TextPrimary = "#1E1B4B",
            TextSecondary = "#4B5563",
            TextDisabled = "#9CA3AF",

            // Icons (default action color)
            ActionDefault = "#8B5CF6",
            ActionDisabled = "#D1D5DB",
            ActionDisabledBackground = "#F3F4F6",

            // Table
            TableLines = "rgba(79,70,229,0.15)",
            TableHover = "rgba(139,92,246,0.08)",
            TableStriped = "rgba(79,70,229,0.04)",

            // Borders / Dividers
            Divider = "rgba(139,92,246,0.18)",
            DividerLight = "rgba(139,92,246,0.08)",

            // Overlays (modal backdrop, dialog)
            OverlayDark = "rgba(15,10,35,0.55)",
            OverlayLight = "rgba(139,92,246,0.06)",

            // Hover / ripple opacities (0.0–1.0)
            HoverOpacity = 0.08,
            RippleOpacity = 0.12,
            RippleOpacitySecondary = 0.10,

            // Gray scale
            GrayLight = "#E5E7EB",
            GrayDefault = "#9CA3AF",
            GrayDark = "#374151",
            GrayLighter = "#F3F4F6",
            GrayDarker = "#1F2937",
        },

        // ── DARK PALETTE ───────────────────────────────────────────────────
        PaletteDark = new PaletteDark
        {
            // Primary — Neon Violet
            Primary = "#8B5CF6",
            PrimaryContrastText = "#FFFFFF",
            PrimaryDarken = "#7C3AED",
            PrimaryLighten = "#A78BFA",

            // Secondary — Neon Cyan
            Secondary = "#06B6D4",
            SecondaryContrastText = "#FFFFFF",
            SecondaryDarken = "#0891B2",
            SecondaryLighten = "#67E8F9",

            // Tertiary — Soft Pink
            Tertiary = "#F472B6",
            TertiaryContrastText = "#1A0020",

            // State colors
            Success = "#10B981",
            SuccessContrastText = "#022C22",
            Warning = "#F59E0B",
            WarningContrastText = "#1A1A1A",
            Error = "#EF4444",
            ErrorContrastText = "#FFFFFF",
            Info = "#3B82F6",
            InfoContrastText = "#FFFFFF",

            // Dark slot — AppBar + Drawer background
            Dark = "#0B0E14",
            DarkContrastText = "#F1F5F9",
            DarkDarken = "#060810",
            DarkLighten = "#131721",

            // Background colors
            Background = "#0B0E14",
            BackgroundGray = "#0F1018",
            Surface = "rgba(255,255,255,0.05)",

            // Navbar / AppBar
            AppbarBackground = "rgba(11,14,20,0.85)",
            AppbarText = "#F1F5F9",

            // Sidebar / Drawer
            DrawerBackground = "rgba(15,10,30,0.90)",
            DrawerText = "#CBD5E1",
            DrawerIcon = "#A78BFA",

            // Text
            TextPrimary = "#F1F5F9",
            TextSecondary = "#CBD5E1",
            TextDisabled = "#4B5563",

            // Icons
            ActionDefault = "#A78BFA",
            ActionDisabled = "#374151",
            ActionDisabledBackground = "#1F2937",

            // Table
            TableLines = "rgba(255,255,255,0.07)",
            TableHover = "rgba(139,92,246,0.15)",
            TableStriped = "rgba(139,92,246,0.06)",

            // Borders / Dividers
            Divider = "rgba(255,255,255,0.10)",
            DividerLight = "rgba(255,255,255,0.05)",

            // Overlays
            OverlayDark = "rgba(0,0,0,0.70)",
            OverlayLight = "rgba(139,92,246,0.08)",

            // Hover / ripple
            HoverOpacity = 0.10,
            RippleOpacity = 0.15,
            RippleOpacitySecondary = 0.12,

            // Gray scale
            GrayLight = "#1F2937",
            GrayDefault = "#374151",
            GrayDark = "#6B7280",
            GrayLighter = "#111827",
            GrayDarker = "#9CA3AF",
        },

        // ── SHAPE (border radius) ───────────────────────────────────────────
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px",
            DrawerWidthLeft = "260px",
            AppbarHeight = "60px",
        },

        // ── Z-INDEX STACK ───────────────────────────────────────────────────
        ZIndex = new ZIndex
        {
            Drawer = 1100,
            AppBar = 1200,
            Dialog = 1300,
            Popover = 1400,
            Tooltip = 1500,
            Snackbar = 1600,
        }
    };
}
