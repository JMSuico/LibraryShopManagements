@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="@(() => _open = !_open)" />
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:600;">Library Shop Management</MudText>
        <MudSpacer />

        @* ── Logged-in user avatar ── *@
        @if (_currentUser != null)
        {
            <MudText Typo="Typo.body2" Class="mr-2" Style="opacity:.9;">
                @_currentUser.Username
            </MudText>
        }

        <MudTooltip Text="@(_currentUser != null ? "Logout" : "Login")" Placement="Placement.Bottom">
            <MudIconButton Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo(_currentUser != null ? "/logout" : "/login"))">
                @if (_currentUser != null && !string.IsNullOrEmpty(_currentUser.ProfileImage))
                {
                    <MudAvatar Style="width:32px;height:32px;border:2px solid rgba(255,255,255,.5);">
                        <MudImage Src="@_currentUser.ProfileImage"
                                  Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else if (_currentUser != null)
                {
                    <MudAvatar Style="background:rgba(255,255,255,.25);color:white;width:32px;height:32px;font-size:.85rem;border:2px solid rgba(255,255,255,.4);">
                        @_currentUser.Username[..1].ToUpper()
                    </MudAvatar>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" />
                }
            </MudIconButton>
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Elevation="2" Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always" Style="background:#FFF1EA;">
        <MudDrawerHeader>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudAvatar Style="background:#FFA07A;color:white;width:36px;height:36px;">L</MudAvatar>
                <MudText Typo="Typo.subtitle1" Style="color:#5C2A10;font-weight:600;">LibraryShop</MudText>
            </MudStack>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _open = true;
    private User? _currentUser;

    protected override void OnInitialized()
    {
        RefreshUser();
        AuthStateProvider.AuthenticationStateChanged += OnAuthChanged;
    }

    private void RefreshUser()
    {
        var p = (CustomAuthenticationStateProvider)AuthStateProvider;
        _currentUser = p.CurrentUser;
    }

    private void OnAuthChanged(Task<AuthenticationState> _)
    {
        RefreshUser();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() =>
        AuthStateProvider.AuthenticationStateChanged -= OnAuthChanged;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#FFA07A",
            PrimaryContrastText = "#FFFFFF",
            Secondary = "#87CEEB",
            SecondaryContrastText = "#1A3A4A",
            AppbarBackground = "#FFA07A",
            AppbarText = "#FFFFFF",
            Background = "#FFF8F5",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFF1EA",
            DrawerText = "#5C2A10",
            TextPrimary = "#3A1A08",
            TextSecondary = "#8C5A3A",
            ActionDefault = "#FFA07A",
            Divider = "#FFD4C2",
        }
    };
}
