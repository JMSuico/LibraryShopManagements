@inject NavigationManager Navigation

<MudNavMenu Style="padding:8px 0;">
    <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-1"
             Style="color:var(--text-accent-violet);font-weight:700;
                    letter-spacing:.12em;font-size:.65rem;">
        NAVIGATION
    </MudText>

    <MudNavLink Href="/home" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home"
                IconColor="Color.Primary">
        Home
    </MudNavLink>
    <MudNavLink Href="/dashboard"
                Icon="@Icons.Material.Filled.Dashboard"
                IconColor="Color.Primary">
        Dashboard
    </MudNavLink>

    <MudDivider Class="my-2" Style="opacity:.4;" />
    <MudText Typo="Typo.overline" Class="px-4 pb-1"
             Style="color:var(--text-accent-cyan);font-weight:700;
                    letter-spacing:.12em;font-size:.65rem;">
        MANAGEMENT
    </MudText>

    <MudNavLink Href="/users"
                Icon="@Icons.Material.Filled.People"
                IconColor="Color.Primary">
        Users
    </MudNavLink>
    <MudNavLink Href="/books"
                Icon="@Icons.Material.Filled.AutoStories"
                IconColor="Color.Primary">
        Books
    </MudNavLink>

    <MudDivider Class="my-2" Style="opacity:.4;" />

    <MudNavLink Href="/logout"
                Icon="@Icons.Material.Filled.Logout"
                IconColor="Color.Error">
        Logout
    </MudNavLink>
</MudNavMenu>
