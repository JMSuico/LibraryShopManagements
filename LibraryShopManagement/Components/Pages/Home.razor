@page "/home"

<PageTitle>Home — Library Shop</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudStack AlignItems="AlignItems.Center" Class="py-10" Spacing="4">
        <MudAvatar Style="background:linear-gradient(135deg,#FFA07A,#87CEEB);width:80px;height:80px;">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="color:white;font-size:2.5rem;" />
        </MudAvatar>
        <MudText Typo="Typo.h4" Style="color:#FFA07A;font-weight:700;">Welcome to Library Shop</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Style="max-width:480px;">
            Manage your library inventory and users with ease.
        </MudText>
        <MudStack Row Spacing="3" Class="mt-4" Wrap="Wrap.Wrap" Justify="Justify.Center">
            <MudButton Href="/dashboard" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Dashboard"
                       Style="border-radius:8px;font-weight:600;">Dashboard</MudButton>
            <MudButton Href="/books" Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.MenuBook"
                       Style="border-radius:8px;font-weight:600;">Manage Books</MudButton>
            <MudButton Href="/users" Variant="Variant.Outlined" Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.People"
                       Style="border-radius:8px;font-weight:600;">Manage Users</MudButton>
        </MudStack>
    </MudStack>
</MudContainer>
