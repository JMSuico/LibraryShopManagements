@page "/users"
@inject IUserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>User Management — Library Shop</PageTitle>

<MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-5">
    <MudText Typo="Typo.h5" Style="color:#FFA07A;font-weight:700;">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />User Management
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenAdd" Style="border-radius:8px;font-weight:600;">
        Add User
    </MudButton>
</MudStack>

<MudPaper Elevation="2" Class="rounded-xl overflow-hidden">
    <MudTable T="User" @ref="_table" ServerData="LoadUsers" Hover Dense Striped
              Loading="_loading" LoadingProgressColor="Color.Primary"
              SortLabel="Sort By" Breakpoint="Breakpoint.Sm">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Search ID, name, username, address, role..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          AdornmentColor="Color.Primary" Variant="Variant.Outlined"
                          Immediate="true" DebounceInterval="300"
                          Clearable Style="max-width:400px;" Class="mt-0"
                          OnKeyUp="OnSearchKeyUp"
                          OnClearButtonClick="ClearSearch" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.Id">ID</MudTableSortLabel></MudTh>
            <MudTh Style="width:52px;">Photo</MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.FirstName">First Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.LastName">Last Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.Username">Username</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.Email">Email</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.Address">Address</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="User" SortBy="u => u.Role.ToString()">Role</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:center;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Photo">
                @if (!string.IsNullOrEmpty(context.ProfileImage))
                {
                    <MudAvatar Style="width:34px;height:34px;">
                        <MudImage Src="@context.ProfileImage" Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Style="background:#FFE4D6;color:#FFA07A;width:34px;height:34px;font-size:.8rem;">
                        @(context.FirstName.Length > 0 ? context.FirstName[..1].ToUpper() : "?")
                    </MudAvatar>
                }
            </MudTd>
            <MudTd DataLabel="First Name"><MudText Style="font-weight:500;">@context.FirstName</MudText></MudTd>
            <MudTd DataLabel="Last Name"><MudText Style="font-weight:500;">@context.LastName</MudText></MudTd>
            <MudTd DataLabel="Username">@context.Username</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Address">
                <MudText Style="max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">
                    @(string.IsNullOrEmpty(context.Address) ? "—" : context.Address)
                </MudText>
            </MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Size="Size.Small" Style="@RoleStyle(context.Role)">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align:center;white-space:nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Color="Color.Secondary" Size="Size.Small"
                               OnClick="@(() => OpenView(context))" Title="View" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => OpenEdit(context))" Title="Edit" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => OpenDelete(context))" Title="Delete" />
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" /></PagerContent>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Style="font-size:3rem;color:#FFD4C2;" />
                <MudText Color="Color.Secondary">No users found.</MudText>
            </MudStack>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<User>? _table;
    private List<User> _allUsers = [];
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try { _allUsers = (await UserService.GetUsersAsync()).ToList(); }
        catch (Exception ex) { Snackbar.Add($"Failed to load: {ex.Message}", Severity.Error); }
        _loading = false;
    }

    // ServerData with in-memory filter+sort — most reliable approach
    private Task<TableData<User>> LoadUsers(TableState state, CancellationToken ct)
    {
        var query = _allUsers.AsQueryable();

        // Search filter
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim().ToLower();
            query = query.Where(u =>
                u.Id.ToString().Contains(s) ||
                u.FirstName.ToLower().Contains(s) ||
                u.LastName.ToLower().Contains(s) ||
                u.FullName.ToLower().Contains(s) ||
                u.Username.ToLower().Contains(s) ||
                u.Email.ToLower().Contains(s) ||
                u.Address.ToLower().Contains(s) ||
                u.Role.ToString().ToLower().Contains(s));
        }

        // Sort
        query = state.SortLabel switch
        {
            "u => u.Id" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.Id) : query.OrderBy(u => u.Id),
            "u => u.FirstName" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.FirstName) : query.OrderBy(u => u.FirstName),
            "u => u.LastName" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.LastName) : query.OrderBy(u => u.LastName),
            "u => u.Username" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.Username) : query.OrderBy(u => u.Username),
            "u => u.Email" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.Email) : query.OrderBy(u => u.Email),
            "u => u.Address" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.Address) : query.OrderBy(u => u.Address),
            "u => u.Role.ToString()" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(u => u.Role.ToString()) : query.OrderBy(u => u.Role.ToString()),
            _ => query.OrderBy(u => u.Id)
        };

        var total = query.Count();
        var items = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new TableData<User> { Items = items, TotalItems = total });
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task ClearSearch()
    {
        _search = string.Empty;
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task Reload()
    {
        _loading = true;
        try { _allUsers = (await UserService.GetUsersAsync()).ToList(); }
        catch (Exception ex) { Snackbar.Add($"Failed to load: {ex.Message}", Severity.Error); }
        _loading = false;
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task OpenView(User user)
    {
        var p = new DialogParameters<UserViewDialog> { { x => x.User, user } };
        var opts = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogService.ShowAsync<UserViewDialog>("User Details", p, opts);
    }

    private async Task OpenAdd()
    {
        var opts = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dlg = await DialogService.ShowAsync<UserFormDialog>("Add User", opts);
        var res = await dlg.Result;
        if (res is { Canceled: false }) { Snackbar.Add("User created!", Severity.Success); await Reload(); }
    }

    private async Task OpenEdit(User user)
    {
        var p = new DialogParameters<UserFormDialog> { { x => x.ExistingUser, user } };
        var opts = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dlg = await DialogService.ShowAsync<UserFormDialog>("Edit User", p, opts);
        var res = await dlg.Result;
        if (res is { Canceled: false }) { Snackbar.Add("User updated!", Severity.Success); await Reload(); }
    }

    private async Task OpenDelete(User user)
    {
        var p = new DialogParameters<ConfirmDialog>
                   { { x => x.Message, $"Do you want to delete \"{user.FullName}\"?" } };
        var opts = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
        var dlg = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", p, opts);
        var res = await dlg.Result;
        if (res is { Canceled: false })
        {
            try { await UserService.DeleteUserAsync(user.Id); Snackbar.Add("User deleted.", Severity.Info); await Reload(); }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    private static string RoleStyle(UserRole r) => r switch
    {
        UserRole.Admin => "background:#FFE4D6;color:#8C3A10;",
        UserRole.Staff => "background:#D6EFFA;color:#1A5C7A;",
        UserRole.Customer => "background:#E8F5E9;color:#2E6B2E;",
        _ => ""
    };
}
