@page "/login"
@layout EmptyLayout
@inject IUserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Login — Library Shop</PageTitle>

<MudPaper Elevation="4" Class="pa-8 rounded-xl" Style="width:100%;max-width:420px;background:white;">
    <MudStack AlignItems="AlignItems.Center" Class="mb-6">
        <MudAvatar Style="background:#FFA07A;width:56px;height:56px;">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="color:white;font-size:1.8rem;" />
        </MudAvatar>
        <MudText Typo="Typo.h5" Style="color:#FFA07A;font-weight:700;">Library Shop</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Sign in to your account</MudText>
    </MudStack>

    <MudSelect T="UserRole" Label="Account Type" @bind-Value="_role" Variant="Variant.Outlined"
               AnchorOrigin="Origin.BottomCenter" Class="mb-4"
               AdornmentIcon="@Icons.Material.Filled.ManageAccounts" AdornmentColor="Color.Primary">
        @foreach (UserRole role in Enum.GetValues(typeof(UserRole)))
        {
            <MudSelectItem Value="role">@role.ToString()</MudSelectItem>
        }
    </MudSelect>

    <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" Class="mb-4"
                  AdornmentIcon="@Icons.Material.Filled.Person" Adornment="Adornment.Start"
                  AdornmentColor="Color.Primary" />

    <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined" Class="mb-6"
                  InputType="@(_showPassword? InputType.Text: InputType.Password)"
                  Adornment="Adornment.End"
                  AdornmentIcon="@(_showPassword? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                  OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                  AdornmentColor="Color.Primary" />

    <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               OnClick="HandleLogin" Disabled="_loading"
               Style="border-radius:8px;font-weight:600;height:48px;">
        @if (_loading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Inherit" />
        }
        else
        {
            <span>Sign In</span>
        }
    </MudButton>

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:#8C5A3A;">
        Don't have an account?
        <MudLink Href="/register" Style="color:#FFA07A;font-weight:600;"> Click Here</MudLink>
    </MudText>
</MudPaper>

@code {
    private UserRole _role = UserRole.Customer;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private bool _showPassword = false;
    private bool _loading = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Please fill in all fields.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var users = await UserService.GetUsersAsync();
            var user = users.FirstOrDefault(u =>
                u.Username.Equals(_username, StringComparison.OrdinalIgnoreCase) &&
                u.Password == _password &&
                u.Role == _role);

            if (user is null)
            {
                Snackbar.Add("Invalid username, password, or account type.", Severity.Error);
                return;
            }

            var provider = (CustomAuthenticationStateProvider)AuthStateProvider;
            provider.MarkUserAsAuthenticated(user);
            Snackbar.Add($"Welcome, {user.Username}!", Severity.Success);
            // ✅ No forceLoad — keeps SignalR circuit alive
            Navigation.NavigateTo("/dashboard");
        }
        finally
        {
            _loading = false;
        }
    }
}
