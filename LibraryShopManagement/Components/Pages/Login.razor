@page "/login"
@layout EmptyLayout
@inject IUserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Sign In — Library Shop</PageTitle>

<MudPaper Elevation="0" Class="auth-card pa-8 rounded-xl"
          Style="width:100%;max-width:420px;">

    @* Header *@
    <MudStack AlignItems="AlignItems.Center" Class="mb-6" Spacing="2">
        <MudAvatar Style="background:var(--cosmic-violet-dim);
                          border:2px solid var(--cosmic-violet);
                          width:64px;height:64px;">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories"
                     Style="color:var(--text-accent-violet);font-size:2rem;" />
        </MudAvatar>
        <MudText Typo="Typo.h5"
                 Style="color:var(--text-heading);font-weight:700;letter-spacing:.03em;">
            Library Shop
        </MudText>
        <MudText Typo="Typo.body2" Style="color:var(--text-muted);">
            Sign in to continue
        </MudText>
    </MudStack>

    @* Account Type *@
    <MudSelect T="UserRole" Label="Account Type" @bind-Value="_role"
               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
               Class="mb-4"
               AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
               AdornmentColor="Color.Primary">
        @foreach (UserRole role in Enum.GetValues(typeof(UserRole)))
        {
            <MudSelectItem Value="role">@role.ToString()</MudSelectItem>
        }
    </MudSelect>

    @* Username *@
    <MudTextField @bind-Value="_username" Label="Username"
                  Variant="Variant.Outlined" Class="mb-4"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Person"
                  AdornmentColor="Color.Primary" />

    @* Password *@
    <MudTextField @bind-Value="_password" Label="Password"
                  Variant="Variant.Outlined" Class="mb-6"
                  InputType="@(_showPwd? InputType.Text: InputType.Password)"
                  Adornment="Adornment.End"
                  AdornmentIcon="@(_showPwd ? Icons.Material.Filled.Visibility
                                                              : Icons.Material.Filled.VisibilityOff)"
                  OnAdornmentClick="@(() => _showPwd = !_showPwd)"
                  AdornmentColor="Color.Primary" />

    @* Sign In *@
    <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary"
               Size="Size.Large" OnClick="HandleLogin" Disabled="_loading"
               Style="border-radius:10px;font-weight:600;height:48px;
                      letter-spacing:.05em;">
        @if (_loading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Inherit" />
        }
        else
        {

            <span>Sign In</span>
        }
    </MudButton>

    <MudDivider Class="my-5" />

    <MudText Typo="Typo.body2" Align="Align.Center"
             Style="color:var(--text-muted);">
        Don't have an account?
        <MudLink Href="/register"
                 Style="color:var(--text-accent-violet);font-weight:600;">
            Click Here
        </MudLink>
    </MudText>
</MudPaper>

@code {
    private UserRole _role = UserRole.Customer;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private bool _showPwd = false;
    private bool _loading = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Please fill in all fields.", Severity.Warning);
            return;
        }
        _loading = true;
        try
        {
            var users = await UserService.GetUsersAsync();
            var user = users.FirstOrDefault(u =>
                u.Username.Equals(_username, StringComparison.OrdinalIgnoreCase) &&
                u.Password == _password &&
                u.Role == _role);

            if (user is null)
            {
                Snackbar.Add("Invalid credentials or account type.", Severity.Error);
                return;
            }
            var provider = (CustomAuthenticationStateProvider)AuthStateProvider;
            provider.MarkUserAsAuthenticated(user);
            Snackbar.Add($"Welcome back, {user.FirstName}!", Severity.Success);
            Navigation.NavigateTo("/dashboard");
        }
        finally { _loading = false; }
    }
}
