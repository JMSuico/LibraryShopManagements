@page "/logout"
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Logout — Library Shop</PageTitle>

<div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:9999;">
    <MudPaper Elevation="8" Class="pa-8 rounded-xl d-flex flex-column align-center" Style="width:380px;max-width:90vw;background:white;">
        <MudAvatar Style="background:#FFE4D6;width:64px;height:64px;" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Logout" Style="color:#FFA07A;font-size:2rem;" />
        </MudAvatar>
        <MudText Typo="Typo.h6" Style="color:#3A1A08;font-weight:700;" Class="mb-2">Sign Out</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mb-6">
            Do you want to logout?<br />You will be returned to the login page.
        </MudText>
        <MudStack Row Spacing="3" Class="w-100">
            <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Default"
                       OnClick="@(() => Navigation.NavigateTo("/dashboard"))"
                       Style="border-radius:8px;font-weight:600;">
                Cancel
            </MudButton>
            <MudButton FullWidth Variant="Variant.Filled" Color="Color.Error"
                       OnClick="HandleLogout"
                       Style="border-radius:8px;font-weight:600;">
                Logout
            </MudButton>
        </MudStack>
    </MudPaper>
</div>

@code {
    private void HandleLogout()
    {
        var provider = (CustomAuthenticationStateProvider)AuthStateProvider;
        provider.MarkUserAsLoggedOut();
        // ✅ No forceLoad — keeps circuit alive, clean nav to login
        Navigation.NavigateTo("/login");
    }
}
