@page "/register"
@layout EmptyLayout
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Register — Library Shop</PageTitle>

<MudPaper Elevation="4" Class="rounded-xl" Style="width:100%;max-width:460px;overflow:hidden;background:white;">

    @* ── Header ── *@
    <div style="background:linear-gradient(135deg,#FFA07A,#87CEEB);padding:28px 32px 20px;">
        <MudStack AlignItems="AlignItems.Center" Spacing="1">
            <MudAvatar Style="background:rgba(255,255,255,.25);width:52px;height:52px;">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="color:white;font-size:1.8rem;" />
            </MudAvatar>
            <MudText Typo="Typo.h5" Style="color:white;font-weight:700;">Create Account</MudText>
            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.85);">
                Step @_step of 2 — @(_step == 1 ? "Personal Info" : "Account Setup")
            </MudText>
        </MudStack>

        @* Step indicator *@
        <MudStack Row Justify="Justify.Center" Spacing="1" Class="mt-3">
            <div style="height:4px;width:80px;border-radius:2px;background:@(_step >= 1 ? "white" : "rgba(255,255,255,.35)");transition:background .3s;"></div>
            <div style="height:4px;width:80px;border-radius:2px;background:@(_step >= 2 ? "white" : "rgba(255,255,255,.35)");transition:background .3s;"></div>
        </MudStack>
    </div>

    @* ── Phase 1: Personal Info ── *@
    @if (_step == 1)
    {
        <MudStack Spacing="3" Class="pa-6">
            <MudTextField @bind-Value="_firstName" Label="First Name" Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_firstName))"
                          ErrorText="First name is required" />

            <MudTextField @bind-Value="_lastName" Label="Last Name" Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_lastName))"
                          ErrorText="Last name is required" />

            <MudSelect T="UserRole" Label="Account Type" @bind-Value="_role"
                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                       AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                       AdornmentColor="Color.Primary">
                @foreach (UserRole r in Enum.GetValues(typeof(UserRole)))
                {
                    <MudSelectItem Value="r">@r.ToString()</MudSelectItem>
                }
            </MudSelect>

            <MudDivider Class="my-1" />

            <MudStack Row Spacing="2">
                <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo("/login"))"
                           Style="border-radius:8px;font-weight:600;">
                    Back to Login
                </MudButton>
                <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="GoToStep2"
                           Style="border-radius:8px;font-weight:600;">
                    Next
                </MudButton>
            </MudStack>
        </MudStack>
    }

    @* ── Phase 2: Account Setup ── *@
    @if (_step == 2)
    {
        <MudStack Spacing="3" Class="pa-6">
            <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.AccountCircle"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_username))"
                          ErrorText="Username is required" />

            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          AdornmentColor="Color.Primary" />

            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                          InputType="@(_showPwd? InputType.Text: InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.Visibility
                                                                           : Icons.Material.Filled.VisibilityOff)"
                      OnAdornmentClick="@(() => _showPwd = !_showPwd)"
                      AdornmentColor="Color.Primary"
                      Immediate="true"
                      Error="@(_showErrors && string.IsNullOrWhiteSpace(_password))"
                      ErrorText="Password is required" />

        <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password"
                      Variant="Variant.Outlined"
                      InputType="@(_showConfirm? InputType.Text: InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.Visibility
                                                                              : Icons.Material.Filled.VisibilityOff)"
                      OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                      AdornmentColor="Color.Primary"
                      Immediate="true"
                      Error="@(_showErrors && _password != _confirmPassword)"
                      ErrorText="Passwords do not match" />

            <MudDivider Class="my-1" />

            <MudStack Row Spacing="2">
                <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => { _step = 1; _showErrors = false; })"
                           Style="border-radius:8px;font-weight:600;">
                    Previous
                </MudButton>
                <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="HandleRegister" Disabled="_loading"
                           Style="border-radius:8px;font-weight:600;">
                @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Inherit" />
                    }
                    else
                    {

                        <span>Create Account</span>
                    }
                </MudButton>
            </MudStack>

            <MudText Typo="Typo.body2" Align="Align.Center" Style="color:#8C5A3A;">
                Already have an account?
                <MudLink Href="/login" Style="color:#FFA07A;font-weight:600;"> Click Here</MudLink>
            </MudText>
        </MudStack>
    }
</MudPaper>

@code {
    private int _step = 1;
    private bool _showErrors = false;
    private bool _loading = false;
    private bool _showPwd = false;
    private bool _showConfirm = false;

    // Phase 1
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private UserRole _role = UserRole.Customer;

    // Phase 2
    private string _username = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;

    private void GoToStep2()
    {
        _showErrors = true;
        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
            return;
        _showErrors = false;
        _step = 2;
    }

    private async Task HandleRegister()
    {
        _showErrors = true;
        if (string.IsNullOrWhiteSpace(_username) ||
            string.IsNullOrWhiteSpace(_password) ||
            _password != _confirmPassword)
            return;

        _loading = true;
        try
        {
            var user = new User
            {
                Role = _role,
                FirstName = _firstName,
                LastName = _lastName,
                Username = _username,
                Email = _email,
                Password = _password
            };
            await UserService.CreateUserAsync(user);
            Snackbar.Add("Account created! Please log in.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }
}
