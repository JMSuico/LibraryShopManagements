@page "/register"
@layout EmptyLayout
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Create Account — Library Shop</PageTitle>

<MudPaper Elevation="0" Class="auth-card rounded-xl"
          Style="width:100%;max-width:460px;overflow:hidden;">

    @* ── Cosmic gradient header ── *@
    <div style="background:linear-gradient(135deg,
                  rgba(139,92,246,.5) 0%,
                  rgba(6,182,212,.3) 100%);
                padding:28px 32px 20px;
                border-bottom:1px solid var(--glass-border);">
        <MudStack AlignItems="AlignItems.Center" Spacing="1">
            <MudAvatar Style="background:var(--cosmic-violet-dim);
                              border:2px solid var(--cosmic-violet);
                              width:52px;height:52px;">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd"
                         Style="color:var(--text-accent-violet);font-size:1.8rem;" />
            </MudAvatar>
            <MudText Typo="Typo.h5"
                     Style="color:var(--text-heading);font-weight:700;">
                Create Account
            </MudText>
            <MudText Typo="Typo.caption"
                     Style="color:rgba(255,255,255,.7);">
                Step @_step of 2 — @(_step == 1 ? "Personal Info" : "Account Setup")
            </MudText>
        </MudStack>
        @* Step pills *@
        <MudStack Row Justify="Justify.Center" Spacing="1" Class="mt-3">
            <div style="height:4px;width:80px;border-radius:2px;
                        background:@(_step >= 1 ? "var(--cosmic-violet)" : "rgba(255,255,255,.2)");
                        box-shadow:@(_step >= 1 ? "var(--glow-violet)" : "none");
                        transition:all .3s;"></div>
            <div style="height:4px;width:80px;border-radius:2px;
                        background:@(_step >= 2 ? "var(--cosmic-cyan)" : "rgba(255,255,255,.2)");
                        box-shadow:@(_step >= 2 ? "var(--glow-cyan)" : "none");
                        transition:all .3s;"></div>
        </MudStack>
    </div>

    @* ── Phase 1 ── *@
    @if (_step == 1)
    {
        <MudStack Spacing="3" Class="pa-6">
            <MudTextField @bind-Value="_firstName" Label="First Name"
                          Variant="Variant.Outlined" Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_firstName))"
                          ErrorText="First name is required" />

            <MudTextField @bind-Value="_lastName" Label="Last Name"
                          Variant="Variant.Outlined" Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_lastName))"
                          ErrorText="Last name is required" />

            <MudSelect T="UserRole" Label="Account Type" @bind-Value="_role"
                       Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                       AdornmentIcon="@Icons.Material.Filled.ManageAccounts"
                       AdornmentColor="Color.Primary">
                @foreach (UserRole r in Enum.GetValues(typeof(UserRole)))
                {
                    <MudSelectItem Value="r">@r.ToString()</MudSelectItem>
                }
            </MudSelect>

            <MudDivider Class="my-1" />
            <MudStack Row Spacing="2">
                <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo("/login"))"
                           Style="border-radius:10px;font-weight:600;">
                    Back to Login
                </MudButton>
                <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="GoToStep2"
                           Style="border-radius:10px;font-weight:600;">
                    Next
                </MudButton>
            </MudStack>
        </MudStack>
    }

    @* ── Phase 2 ── *@
    @if (_step == 2)
    {
        <MudStack Spacing="3" Class="pa-6">
            <MudTextField @bind-Value="_username" Label="Username"
                          Variant="Variant.Outlined" Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.AccountCircle"
                          AdornmentColor="Color.Primary"
                          Error="@(_showErrors && string.IsNullOrWhiteSpace(_username))"
                          ErrorText="Username is required" />

            <MudTextField @bind-Value="_email" Label="Email"
                          Variant="Variant.Outlined" InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          AdornmentColor="Color.Primary" />

            <MudTextField @bind-Value="_password" Label="Password"
                          Variant="Variant.Outlined" Immediate="true"
                          InputType="@(_showPwd? InputType.Text: InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.Visibility
                                                                          : Icons.Material.Filled.VisibilityOff)"
                      OnAdornmentClick="@(() => _showPwd = !_showPwd)"
                      AdornmentColor="Color.Primary"
                      Error="@(_showErrors && string.IsNullOrWhiteSpace(_password))"
                      ErrorText="Password is required" />

        <MudTextField @bind-Value="_confirmPwd" Label="Confirm Password"
                      Variant="Variant.Outlined" Immediate="true"
                      InputType="@(_showConfirm? InputType.Text: InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.Visibility
                                                                              : Icons.Material.Filled.VisibilityOff)"
                      OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                      AdornmentColor="Color.Primary"
                      Error="@(_showErrors && _password != _confirmPwd)"
                      ErrorText="Passwords do not match" />

            <MudDivider Class="my-1" />
            <MudStack Row Spacing="2">
                <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => { _step = 1; _showErrors = false; })"
                           Style="border-radius:10px;font-weight:600;">
                    Previous
                </MudButton>
                <MudButton FullWidth Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="HandleRegister" Disabled="_loading"
                           Style="border-radius:10px;font-weight:600;">
                @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Inherit" />
                    }
                    else
                    {

                        <span>Create Account</span>
                    }
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Align="Align.Center"
                     Style="color:var(--text-muted);">
                Already have an account?
                <MudLink Href="/login"
                         Style="color:var(--text-accent-violet);font-weight:600;">
                    Click Here
                </MudLink>
            </MudText>
        </MudStack>
    }
</MudPaper>

@code {
    private int _step = 1;
    private bool _showErrors = false;
    private bool _loading = false;
    private bool _showPwd = false;
    private bool _showConfirm = false;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private UserRole _role = UserRole.Customer;
    private string _username = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPwd = string.Empty;

    private void GoToStep2()
    {
        _showErrors = true;
        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName)) return;
        _showErrors = false;
        _step = 2;
    }

    private async Task HandleRegister()
    {
        _showErrors = true;
        if (string.IsNullOrWhiteSpace(_username) ||
            string.IsNullOrWhiteSpace(_password) ||
            _password != _confirmPwd) return;

        _loading = true;
        try
        {
            await UserService.CreateUserAsync(new User
            {
                Role = _role,
                FirstName = _firstName,
                LastName = _lastName,
                Username = _username,
                Email = _email,
                Password = _password
            });
            Snackbar.Add("Account created! Please sign in.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }
}
