@inject IUserService UserService
@inject ISnackbar Snackbar

<MudDialog Style="min-width:460px;max-height:90vh;overflow-y:auto;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight:700;">
                @(ExistingUser == null ? "Add New User" : "Edit User")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-weight:600;">Profile Photo</MudText>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                @if (!string.IsNullOrEmpty(_user.ProfileImage))
                {
                    <MudAvatar Color="Color.Primary" Style="width:68px;height:68px;border:2px solid var(--clr-primary);">
                        <MudImage Src="@_user.ProfileImage" Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Color="Color.Primary" Style="width:68px;height:68px;font-size:1.6rem;">
                        @(_user.FirstName.Length > 0 ? _user.FirstName[..1].ToUpper() : "?")
                    </MudAvatar>
                }
                <MudStack Spacing="1">
                    <InputFile id="user-photo-input" OnChange="UploadPhoto" accept="image/*" style="display:none;" />
                    <label for="user-photo-input" style="cursor:pointer;">
                        <MudButton HtmlTag="span" Variant="Variant.Outlined" Color="Color.Primary"
                                   Size="Size.Small" StartIcon="@Icons.Material.Filled.Upload"
                                   Style="border-radius:6px;pointer-events:none;">Upload Photo</MudButton>
                    </label>
                    @if (!string.IsNullOrEmpty(_user.ProfileImage))
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                   OnClick="@(() => { _user.ProfileImage = null; StateHasChanged(); })">Remove</MudButton>
                    }
                </MudStack>
            </MudStack>
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-weight:600;">Personal Information</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField @bind-Value="_user.FirstName" Label="First Name" Variant="Variant.Outlined"
                                  Immediate="true" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person" AdornmentColor="Color.Primary" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_user.LastName" Label="Last Name" Variant="Variant.Outlined" Immediate="true" />
                </MudItem>
            </MudGrid>
            <MudTextField @bind-Value="_user.Address" Label="Address" Variant="Variant.Outlined" Lines="2"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Home" AdornmentColor="Color.Primary" />
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-weight:600;">Account Information</MudText>
            <MudSelect T="UserRole" Label="Account Type" @bind-Value="_user.Role" Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       AdornmentIcon="@Icons.Material.Filled.ManageAccounts" AdornmentColor="Color.Primary">
                @foreach (UserRole r in Enum.GetValues(typeof(UserRole)))
                {
                    <MudSelectItem Value="r">@r.ToString()</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_user.Username" Label="Username" Variant="Variant.Outlined" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountCircle" AdornmentColor="Color.Primary" />
            <MudTextField @bind-Value="_user.Email" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" AdornmentColor="Color.Primary" />
            <MudTextField @bind-Value="_user.Password" Label="Password" Variant="Variant.Outlined"
                          InputType="@(_showPwd? InputType.Text: InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="@(() => _showPwd = !_showPwd)" AdornmentColor="Color.Primary" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Style="font-weight:600;" OnClick="Submit" Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate />
            }
            else
            {

                <span>@(ExistingUser == null ? "Add User" : "Save Changes")</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public User? ExistingUser { get; set; }
    private User _user = new(); private bool _showPwd, _saving;
    protected override void OnInitialized()
    {
        if (ExistingUser != null)
            _user = new User
            {
                Id = ExistingUser.Id,
                Role = ExistingUser.Role,
                FirstName = ExistingUser.FirstName,
                LastName = ExistingUser.LastName,
                Address = ExistingUser.Address,
                Username = ExistingUser.Username,
                Email = ExistingUser.Email,
                Password = ExistingUser.Password,
                ProfileImage = ExistingUser.ProfileImage
            };
    }
    private async Task UploadPhoto(InputFileChangeEventArgs e)
    {
        try
        {
            var f = e.File; using var s = f.OpenReadStream(5 * 1024 * 1024); var b = new byte[f.Size];
            await s.ReadAsync(b); _user.ProfileImage = $"data:{f.ContentType};base64,{Convert.ToBase64String(b)}";
            StateHasChanged();
        }
        catch { Snackbar.Add("Image too large (max 5 MB).", Severity.Warning); }
    }
    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_user.FirstName)) { Snackbar.Add("First name required.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_user.Username)) { Snackbar.Add("Username required.", Severity.Warning); return; }
        _saving = true;
        try
        {
            if (ExistingUser == null) await UserService.CreateUserAsync(_user); else await UserService.UpdateUserAsync(_user);
            MudDialog.Close(DialogResult.Ok(_user));
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}
