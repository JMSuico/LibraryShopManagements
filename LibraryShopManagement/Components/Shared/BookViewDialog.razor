<MudDialog Style="min-width:380px;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight:700;">Book Details</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Book != null)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                @if (!string.IsNullOrEmpty(Book.CoverImage))
                {
                    <MudAvatar Color="Color.Secondary" Style="width:100px;height:130px;border-radius:8px;border:3px solid var(--clr-secondary);">
                        <MudImage Src="@Book.CoverImage" Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Color="Color.Secondary" Style="width:100px;height:130px;border-radius:8px;font-size:2.5rem;border:3px solid var(--clr-secondary);">
                        @(Book.Title.Length > 0 ? Book.Title[..1].ToUpper() : "?")
                    </MudAvatar>
                }
                <MudText Typo="Typo.h6" Color="Color.Default" Style="font-weight:700;margin-top:10px;text-align:center;">@Book.Title</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">by @Book.Author</MudText>
            </MudStack>
            <MudDivider Class="mb-3" />
            <MudStack Spacing="2">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Tag" Color="Color.Secondary" Style="font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Book ID</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Default" Style="font-weight:500;">#@Book.Id</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Secondary" Style="font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Price</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight:600;">&#8369;@Book.Price.ToString("F2")</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Secondary" Style="font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Stock</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Class="@(Book.Stock < 5 ? "chip-stock-low" : "chip-stock-ok")">
                            @Book.Stock @(Book.Stock == 1 ? "copy" : "copies")
                        </MudChip>
                    </div>
                </MudStack>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Style="font-weight:600;"
                   OnClick="@(() => MudDialog.Cancel())">Close</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Book? Book { get; set; }
}
