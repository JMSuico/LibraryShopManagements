<MudDialog Style="min-width:420px;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Style="color:#FFA07A;" />
            <MudText Typo="Typo.h6" Style="color:#FFA07A;font-weight:700;">User Details</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (User != null)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                @if (!string.IsNullOrEmpty(User.ProfileImage))
                {
                    <MudAvatar Style="width:90px;height:90px;border:3px solid #FFA07A;">
                        <MudImage Src="@User.ProfileImage" Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Style="background:#FFE4D6;color:#FFA07A;width:90px;height:90px;font-size:2.2rem;border:3px solid #FFD4C2;">
                        @(User.FirstName.Length > 0 ? User.FirstName[..1].ToUpper() : "?")
                    </MudAvatar>
                }
                <MudText Typo="Typo.h6" Style="color:#3A1A08;font-weight:700;margin-top:8px;">
                    @User.FullName
                </MudText>
                <MudChip T="string" Size="Size.Small" Style="@RoleStyle(User.Role)">@User.Role</MudChip>
            </MudStack>

            <MudDivider Class="mb-3" />

            <MudStack Spacing="2">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Badge" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ID</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">#@User.Id</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">First Name</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@User.FirstName</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Last Name</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@User.LastName</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Username</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@User.Username</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Email" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@(string.IsNullOrEmpty(User.Email) ? "—" : User.Email)</MudText>
                    </div>
                </MudStack>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Home" Style="color:#FFA07A;font-size:1.1rem;" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Address</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@(string.IsNullOrEmpty(User.Address) ? "—" : User.Address)</MudText>
                    </div>
                </MudStack>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Style="font-weight:600;" OnClick="@(() => MudDialog.Cancel())">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public User? User { get; set; }

    private static string RoleStyle(UserRole r) => r switch
    {
        UserRole.Admin => "background:#FFE4D6;color:#8C3A10;",
        UserRole.Staff => "background:#D6EFFA;color:#1A5C7A;",
        UserRole.Customer => "background:#E8F5E9;color:#2E6B2E;",
        _ => ""
    };
}
