<MudDialog Style="min-width:400px;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight:700;">User Details</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (User != null)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                @if (!string.IsNullOrEmpty(User.ProfileImage))
                {
                    <MudAvatar Color="Color.Primary" Style="width:90px;height:90px;border:3px solid var(--clr-primary);">
                        <MudImage Src="@User.ProfileImage" Style="width:100%;height:100%;object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Color="Color.Primary" Style="width:90px;height:90px;font-size:2.2rem;border:3px solid var(--clr-primary);">
                        @(User.FirstName.Length > 0 ? User.FirstName[..1].ToUpper() : "?")
                    </MudAvatar>
                }
                <MudText Typo="Typo.h6" Color="Color.Default" Style="font-weight:700;margin-top:8px;">@User.FullName</MudText>
                <MudChip T="string" Size="Size.Small" Class="@RoleChipClass(User.Role)">@User.Role</MudChip>
            </MudStack>
            <MudDivider Class="mb-3" />
            <MudStack Spacing="2">
                @foreach (var (icon, label, value) in Fields())
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@icon" Color="Color.Primary" Style="font-size:1.1rem;" />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@label</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Default" Style="font-weight:500;">@value</MudText>
                        </div>
                    </MudStack>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Style="font-weight:600;"
                   OnClick="@(() => MudDialog.Cancel())">Close</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public User? User { get; set; }

    private IEnumerable<(string icon, string label, string value)> Fields() =>
    [
        (Icons.Material.Filled.Badge,         "ID",         $"#{User!.Id}"),
        (Icons.Material.Filled.Person,        "First Name", User!.FirstName),
        (Icons.Material.Filled.Person,        "Last Name",  User!.LastName),
        (Icons.Material.Filled.AccountCircle, "Username",   User!.Username),
        (Icons.Material.Filled.Email,         "Email",      string.IsNullOrEmpty(User!.Email) ? "—" : User!.Email),
        (Icons.Material.Filled.Home,          "Address",    string.IsNullOrEmpty(User!.Address) ? "—" : User!.Address),
    ];

    private static string RoleChipClass(UserRole r) => r switch
    {
        UserRole.Admin => "chip-role-admin",
        UserRole.Staff => "chip-role-staff",
        UserRole.Customer => "chip-role-customer",
        _ => ""
    };
}
