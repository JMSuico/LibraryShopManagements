@page "/borrow"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Librarian")]
@inject IBorrowService BorrowService
@inject ISnackbar Snackbar

<PageTitle>Borrow Logs - Glass Library Management</PageTitle>

<MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-5" Style="font-weight:700;">
    <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Class="mr-2" Color="Color.Primary" />
    Borrow Logs
</MudText>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Transaction history for every loan: borrower, staff member who verified the checkout (when recorded), book, dates, time remaining on active loans, status, and fines.
</MudText>

<MudPaper Elevation="3" Class="pa-4 rounded-xl overflow-hidden">
    <MudTable Items="_transactions" Dense Hover Breakpoint="Breakpoint.Sm" RowsPerPage="15">
        <HeaderContent>
            <MudTh>Borrower</MudTh>
            <MudTh>Verified by</MudTh>
            <MudTh>Book</MudTh>
            <MudTh>Borrowed</MudTh>
            <MudTh>Due</MudTh>
            <MudTh>Returned</MudTh>
            <MudTh>Time remaining</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Fine</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@(context.User?.FullName ?? "Unknown")</MudTd>
            <MudTd>@(context.VerifiedByUser?.FullName ?? "—")</MudTd>
            <MudTd>@(context.Book?.Title ?? "Unknown")</MudTd>
            <MudTd>@context.BorrowedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudTd>
            <MudTd>@context.DueAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudTd>
            <MudTd>@(context.ReturnedAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "—")</MudTd>
            <MudTd>@(context.ReturnedAt == null ? DateHelper.FormatTimeRemaining(context.DueAt, _nowUtc) : "—")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>@context.FineAmount.ToString("F2")</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No borrow records yet.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<BorrowTransaction> _transactions = [];
    private DateTime _nowUtc = DateHelper.UtcNow();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        try
        {
            _nowUtc = DateHelper.UtcNow();
            _transactions = (await BorrowService.GetBorrowLogsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load borrow logs: {ex.Message}", Severity.Error);
        }
    }

    private static Color StatusColor(TransactionStatus status) => status switch
    {
        TransactionStatus.Returned => Color.Success,
        TransactionStatus.Overdue => Color.Error,
        _ => Color.Warning
    };
}
