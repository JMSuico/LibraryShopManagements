@page "/borrow-and-return"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Librarian")]
@inject IBorrowAndReturnService BorrowAndReturnService
@inject IReturnService ReturnService
@inject IBookService BookService
@inject IUserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Borrow and Return - Glass Library Management</PageTitle>

<MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-5" Style="font-weight:700;">
    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-2" Color="Color.Primary" />
    Borrow and Return
</MudText>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Circulation desk: borrow with or without a prior reservation (direct borrow supports quantity), or return items that are still checked out. Your account is recorded as the staff member who verified each checkout.
</MudText>

<MudTabs Elevation="4" Rounded="true" Color="Color.Primary" Centered="true" Class="mb-6">
    <MudTabPanel Text="Borrow" Icon="@Icons.Material.Filled.LibraryAdd">
        <MudGrid Spacing="4" Class="mt-2">
            <MudItem xs="12" md="5">
                <MudPaper Elevation="3" Class="pa-4 rounded-xl">
                    <MudText Typo="Typo.h6" Class="mb-3">Direct borrow (quantity)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        For patrons without an active reservation: select account, title, and how many copies to check out at once (subject to limits and availability).
                    </MudText>

                    <MudAutocomplete T="User" Label="Patron account" @bind-Value="_directUser"
                                     SearchFunc="@SearchUsers" ToStringFunc="@(u => u?.FullName ?? "")"
                                     ResetValueOnEmptyText="true" CoerceText="true" CoerceValue="true"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />

                    <MudAutocomplete T="Book" Label="Book" @bind-Value="_directBook"
                                     SearchFunc="@SearchBooks" ToStringFunc="@(b => b?.Title ?? "")"
                                     ResetValueOnEmptyText="true" CoerceText="true" CoerceValue="true"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />

                    <MudNumericField T="int" Label="Quantity" @bind-Value="_directQuantity" Min="1"
                                     Max="@(_directBook?.Quantity ?? 1)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="HandleDirectBorrowAsync"
                               Disabled="@(_directBook == null || _directUser == null || _directQuantity < 1 || !_staffId.HasValue)">
                        Confirm direct borrow
                    </MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Elevation="3" Class="pa-4 rounded-xl">
                    <MudText Typo="Typo.h6" Class="mb-3">Available books</MudText>
                    <MudTable Items="_books" Dense="true" Hover="true" RowsPerPage="5">
                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Author</MudTh>
                            <MudTh>Qty</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Title</MudTd>
                            <MudTd>@context.Author</MudTd>
                            <MudTd>@context.Quantity</MudTd>
                            <MudTd>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="@(() => SelectBook(context))">Select</MudButton>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <MudTabPanel Text="Return" Icon="@Icons.Material.Filled.AssignmentReturn">
        <MudGrid Spacing="4" Class="mt-2">
            <MudItem xs="12">
                <MudPaper Elevation="3" Class="pa-4 rounded-xl">
                    <MudText Typo="Typo.h6" Class="mb-3">Checked-out items</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Everything listed here is still on loan. You can select specific copies to return.
                    </MudText>
                    <MudTable Items="_activeTransactions" Dense="true" Hover="true" RowsPerPage="8" MultiSelection="true" @bind-SelectedItems="_selectedReturns">
                        <HeaderContent>
                            <MudTh>Borrower</MudTh>
                            <MudTh>Book</MudTh>
                            <MudTh>Copy ID</MudTh>
                            <MudTh>Borrowed</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.User?.FullName</MudTd>
                            <MudTd>@context.Book?.Title</MudTd>
                            <MudTd>@(context.QRCode?.CopyId ?? "N/A")</MudTd>
                            <MudTd>@context.BorrowedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                    
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-4" OnClick="OpenBulkReturnConfirmAsync" Disabled="!_selectedReturns.Any()">
                        Return Selected (@_selectedReturns.Count)
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>

@code {
    private List<Book> _books = [];
    private List<User> _users = [];
    private List<BorrowTransaction> _allTransactions = [];
    private IEnumerable<BorrowTransaction> _activeTransactions => _allTransactions.Where(t => t.ReturnedAt == null);
    private HashSet<BorrowTransaction> _selectedReturns = new();

    private Book? _directBook;
    private User? _directUser;
    private int _directQuantity = 1;
    private int? _staffId;

    protected override async Task OnInitializedAsync()
    {
        var provider = (AppAuthenticationStateProvider)AuthStateProvider;
        _staffId = provider.CurrentUser?.Id;
        await Reload();
    }

    private async Task Reload()
    {
        try
        {
            _books = (await BookService.GetAvailableBooksAsync()).ToList();
            _users = (await UserService.GetUsersAsync()).ToList();
            _allTransactions = (await BorrowAndReturnService.GetTransactionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private Task<IEnumerable<Book>> SearchBooks(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return Task.FromResult<IEnumerable<Book>>(_books);
        return Task.FromResult<IEnumerable<Book>>(_books.Where(x => x.Title.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private Task<IEnumerable<User>> SearchUsers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return Task.FromResult<IEnumerable<User>>(_users);
        return Task.FromResult<IEnumerable<User>>(_users.Where(x => x.FullName.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void SelectBook(Book book)
    {
        _directBook = book;
    }

    private async Task HandleDirectBorrowAsync()
    {
        if (_directBook == null || _directUser == null || !_staffId.HasValue)
        {
            return;
        }

        try
        {
            var qrCodeIds = _directBook.QRCodes?
                .Where(q => q.IsAvailable)
                .Take(_directQuantity)
                .Select(q => q.Id)
                .ToList() ?? new List<int>();

            await BorrowAndReturnService.DirectBorrowAsync(
                _directBook.Id,
                _directUser.Id,
                qrCodeIds,
                DateHelper.DefaultBorrowDays,
                _staffId.Value);
            Snackbar.Add("Direct borrow recorded.", Severity.Success);
            _directBook = null;
            _directUser = null;
            _directQuantity = 1;
            await Reload();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenBulkReturnConfirmAsync()
    {
        if (!_selectedReturns.Any()) return;

        try
        {
            var firstItem = _selectedReturns.First();
            var preview = await ReturnService.GetReturnPreviewAsync(firstItem.Id);
            var proposed = DateHelper.UtcNow();
            
            // Note: Since we are allowing bulk returns across different books/users,
            // we will pass the list of selected transaction IDs to the custom action
            // and adapt the dialog slightly or just use it as a confirmation wrapper.
            // For now, we'll reuse ReturnConfirmDialog but we might need a Bulk version.
            
            var parameters = new DialogParameters<ReturnConfirmDialog>
            {
                { x => x.Preview, preview }, // Just use the first one for preview details if needed
                { x => x.ProposedReturnUtc, proposed },
                { x => x.CustomReturnByTransactionIdAsync, new Func<int, Task>(async _ => 
                    {
                        foreach (var tx in _selectedReturns)
                        {
                            await BorrowAndReturnService.ReturnAsync(tx.Id);
                        }
                    }) 
                },
                { x => x.IsBulk, true },
                { x => x.BulkCount, _selectedReturns.Count }
            };

            var dialog = await DialogService.ShowAsync<ReturnConfirmDialog>(
                "Confirm return",
                parameters,
                new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

            var result = await dialog.Result;
            if (result is { Canceled: false })
            {
                Snackbar.Add($"Recorded return for {_selectedReturns.Count} items.", Severity.Success);
                _selectedReturns.Clear();
                await Reload();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
