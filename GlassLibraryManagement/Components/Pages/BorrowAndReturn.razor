@page "/borrow-and-return"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Librarian")]
@inject IBorrowAndReturnService BorrowAndReturnService
@inject IReturnService ReturnService
@inject IBookService BookService
@inject IUserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Borrow and Return - Glass Library Management</PageTitle>

<MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-5" Style="font-weight:700;">
    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-2" Color="Color.Primary" />
    Borrow and Return
</MudText>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Circulation desk: borrow with or without a prior reservation (direct borrow supports quantity), or return items that are still checked out. Your account is recorded as the staff member who verified each checkout.
</MudText>

<MudTabs Elevation="4" Rounded="true" Color="Color.Primary" Centered="true" Class="mb-6">
    <MudTabPanel Text="Borrow" Icon="@Icons.Material.Filled.LibraryAdd">
        <MudGrid Spacing="4" Class="mt-2">
            <MudItem xs="12">
                <MudPaper Elevation="3" Class="pa-4 rounded-xl">
                    <MudText Typo="Typo.h6" Class="mb-3">Available books</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Click 'Borrow' to open the borrowing modal and select specific copies.
                    </MudText>
                    <MudTable Items="_books" Dense="true" Hover="true" RowsPerPage="10">
                        <ToolBarContent>
                            <MudTextField @bind-Value="_searchBook" Placeholder="Search books..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" />
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Author</MudTh>
                            <MudTh>Qty Available</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Title</MudTd>
                            <MudTd>@context.Author</MudTd>
                            <MudTd>@context.AvailableCopies</MudTd>
                            <MudTd Style="text-align:right;">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenBorrowModalAsync(context))">Borrow</MudButton>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <MudTabPanel Text="Return" Icon="@Icons.Material.Filled.AssignmentReturn">
        <MudGrid Spacing="4" Class="mt-2">
            <MudItem xs="12">
                <MudPaper Elevation="3" Class="pa-4 rounded-xl">
                    <MudText Typo="Typo.h6" Class="mb-3">Checked-out items</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Everything listed here is still on loan. Click 'Return Books' to select specific copies to return.
                    </MudText>
                    <MudTable Items="_groupedTransactions" Dense="true" Hover="true" RowsPerPage="8">
                        <HeaderContent>
                            <MudTh>Borrower</MudTh>
                            <MudTh>Book</MudTh>
                            <MudTh>Copies Borrowed</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.First().User?.FullName</MudTd>
                            <MudTd>@context.First().Book?.Title</MudTd>
                            <MudTd>@context.Count()</MudTd>
                            <MudTd Style="text-align:right;">
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" OnClick="@(() => OpenReturnModalAsync(context))">
                                    Return Books
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>

@code {
    private List<Book> _books = [];
    private List<User> _users = [];
    private List<BorrowTransaction> _allTransactions = [];
    private IEnumerable<IGrouping<(int UserId, int BookId), BorrowTransaction>> _groupedTransactions => 
        _allTransactions.Where(t => t.ReturnedAt == null)
                        .GroupBy(t => (t.UserId, t.BookId));

    private string _searchBook = string.Empty;
    private int? _staffId;

    protected override async Task OnInitializedAsync()
    {
        var provider = (AppAuthenticationStateProvider)AuthStateProvider;
        _staffId = provider.CurrentUser?.Id;
        await Reload();
    }

    private async Task Reload()
    {
        try
        {
            _books = (await BookService.GetAvailableBooksAsync()).ToList();
            _users = (await UserService.GetUsersAsync()).ToList();
            _allTransactions = (await BorrowAndReturnService.GetTransactionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private Task<IEnumerable<Book>> SearchBooks(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return Task.FromResult<IEnumerable<Book>>(_books);
        return Task.FromResult<IEnumerable<Book>>(_books.Where(x => x.Title.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private Task<IEnumerable<User>> SearchUsers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return Task.FromResult<IEnumerable<User>>(_users);
        return Task.FromResult<IEnumerable<User>>(_users.Where(x => x.FullName.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OpenBorrowModalAsync(Book book)
    {
        var parameters = new DialogParameters<BorrowDialog> { { x => x.Book, book } };
        var dialog = await DialogService.ShowAsync<BorrowDialog>("Borrow Books", parameters, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Borrow recorded.", Severity.Success);
            await Reload();
        }
    }

    private async Task OpenReturnModalAsync(IGrouping<(int UserId, int BookId), BorrowTransaction> group)
    {
        try
        {
            var parameters = new DialogParameters<ReturnBooksDialog>
            {
                { x => x.Transactions, group.ToList() }
            };

            var dialog = await DialogService.ShowAsync<ReturnBooksDialog>(
                "Return Books",
                parameters,
                new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true });

            var result = await dialog.Result;
            if (result is { Canceled: false } && result.Data is List<int> returnedIds)
            {
                foreach (var id in returnedIds)
                {
                    await BorrowAndReturnService.ReturnAsync(id);
                }
                Snackbar.Add($"Recorded return for {returnedIds.Count} items.", Severity.Success);
                await Reload();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
