@using GlassLibraryManagement.Features.Data.Models

<MudDialog Style="min-width:440px;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Color="Color.Warning" Style="font-weight:700;">Cancel Reservation</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body1">How many copies of <strong>@Reservation.Book?.Title</strong> do you want to cancel?</MudText>
            
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudNumericField T="int" @bind-Value="_cancelQuantity" Min="1" Max="@Reservation.Quantity" 
                             Label="Quantity to Cancel" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="CancelAll">Cancel All</MudButton>
        </MudStack>
            
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Remaining reservations after cancel: @(Reservation.Quantity - _cancelQuantity)
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Keep Hold</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="Submit">Cancel Reservation</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public Reservation Reservation { get; set; } = default!;
    
    private int _cancelQuantity;
    
    protected override void OnInitialized()
    {
        _cancelQuantity = Reservation.Quantity;
    }

    private void CancelAll()
    {
        _cancelQuantity = Reservation.Quantity;
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    
    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(_cancelQuantity));
    }
}