@inject IReturnService ReturnService
@inject ISnackbar Snackbar

<MudDialog Style="min-width:440px;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentReturn" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight:700;">Confirm Return</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (IsBulk)
            {
                <MudText Typo="Typo.h6">Returning @BulkCount items</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Return time: @ProposedReturnUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Are you sure you want to return all selected items? Fines (if any) will be calculated based on the return time.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.h6">@(Preview.Book?.Title ?? "Unknown book")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Borrower: @(Preview.User?.FullName ?? "Unknown")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Borrowed: @Preview.BorrowedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Due: @Preview.DueAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Return time: @ProposedReturnUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</MudText>

                @if (DateHelper.IsOverdue(Preview.DueAt, ProposedReturnUtc))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
                        This loan is overdue. Estimated fine: @_previewFine.ToString("F2")
                    </MudAlert>
                }
                else if (_previewFine > 0)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                        Fine at return: @_previewFine.ToString("F2")
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                        No fine for an on-time return.
                    </MudAlert>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Submit" Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate />
            }
            else
            {
                <span>Confirm Return</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public BorrowTransaction Preview { get; set; } = default!;
    [Parameter] public DateTime ProposedReturnUtc { get; set; }
    /// <summary>Optional override for return commit (e.g. staff transact flow).</summary>
    [Parameter] public Func<int, Task>? CustomReturnByTransactionIdAsync { get; set; }
    [Parameter] public bool IsBulk { get; set; }
    [Parameter] public int BulkCount { get; set; }

    private bool _saving;
    private decimal _previewFine;

    protected override void OnParametersSet()
    {
        if (Preview != null)
        {
            _previewFine = FineHelper.CalculateFine(Preview.DueAt, ProposedReturnUtc);
        }
    }

    private async Task Submit()
    {
        _saving = true;
        try
        {
            if (CustomReturnByTransactionIdAsync != null)
            {
                await CustomReturnByTransactionIdAsync(Preview.Id);
            }
            else
            {
                await ReturnService.ReturnAsync(Preview.Id);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
